# ===== 服务端口 =====
# 注意：ECS 上 3000 被 next-server 占、8000 被 FastAPI 占，本服务用 3030
PORT=3030
NODE_ENV=development

# ===== JWT =====
# 用 openssl rand -hex 32 生成
JWT_SECRET=replace_me_with_a_64_char_random_hex
JWT_EXPIRES_IN=30d

# ===== 微信小程序 =====
WX_APPID=
WX_APP_SECRET=

# ===== Supabase（复用 Lumina-trip 现有项目）=====
SUPABASE_URL=https://xxxxxxxxx.supabase.co
# 注意：BFF 用 service_role，不能暴露给前端；W2 改造 schema 时建议 rotate 一次
SUPABASE_SERVICE_ROLE_KEY=

# ===== nginx 反代路径前缀（BFF 不感知，仅用于客户端拼链）=====
# 客户端访问：https://cuizhexiao.xyz/lumina-api/* → nginx → 127.0.0.1:3030/api/*

# ===== AI / 第三方 =====
DEEPSEEK_KEY=
ZHIPU_KEY=
AMAP_KEY=
QWEATHER_KEY=
QWEATHER_HOST=

# ===== 限流 / 预算 =====
DAILY_AI_QUOTA_PER_USER=3
DAILY_GLOBAL_BUDGET_CNY=10
NEW_USER_DAILY_AI_QUOTA=1

# ===== 告警邮箱（W8）=====
ALERT_EMAIL=
